# Root build context (docker-publish.yml builds with context: .).
# Keep the context lean and never ship host artifacts into images.
**/node_modules
**/dist
**/coverage
**/.vite
.git
.github
**/*.log
npm-debug.log*
.DS_Store
**/.env
**/.env.*
docker-compose*.yml
**/Dockerfile
.dockerignore
.claude
# Native Capacitor projects — not needed for the web build the image serves.
frontend/android
frontend/ios

# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Backend
# Don't blanket-ignore backend/data/ — the scanner matcher's pHash +
# MobileCLIP artifacts under backend/data/scanner/ ship in git so the
# Docker image is reproducible across deploys (refreshed nightly by
# .github/workflows/scanner-ingest.yml). Ignore the SQLite cache files
# specifically instead.
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal
backend/data/offline-oracle.*
backend/data/scryfall-bulk.meta.json
backend/dist/

# Frontend
frontend/dist/
frontend/.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
.env
.env.local
.env.*.local

# Claude Code
.claude/
CLAUDE.md
AGENTS.md
docs/

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Coverage / testing
coverage/
.nyc_output/

# Misc
*.pid
*.seed
*.pid.lock

# Agent-generated brainstorming/spec/plan docs — keep them out of the repo.
# (`docs/` itself stays usable for real project docs.)
docs/superpowers/

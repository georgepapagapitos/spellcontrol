# Copy to .env on the host and fill in real values before `docker compose up`.

# Postgres password used by both the postgres container and the backend's
# DATABASE_URL. Generate something random — this never needs to be typed
# anywhere by hand.
POSTGRES_PASSWORD=change-me

# Signing key for session JWTs. Must be at least 16 chars; aim for 32+ random
# characters. Rotating this invalidates every active session.
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

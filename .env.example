# Copy to .env on the host and fill in real values before `docker compose up`.

# Postgres password used by both the postgres container and the backend's
# DATABASE_URL. Generate something random — this never needs to be typed
# anywhere by hand.
POSTGRES_PASSWORD=change-me

# Signing key for session JWTs. Must be at least 16 chars; aim for 32+ random
# characters. Rotating this invalidates every active session.
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Optional. Comma-separated usernames that get the `admin` role. On every
# backend boot any matching existing user is promoted; new registrations
# matching the list start out as admin. Additive — removing a name here
# never demotes anyone (use the admin UI or SQL for that). Leave unset
# for an admin-less deploy.
#ADMIN_USERNAMES=alice,bob

# Optional — "Continue with Google" sign-in. Leave all four unset to disable
# Google SSO entirely (the backend boots fine and the frontend hides the
# button). Create an OAuth 2.0 Client (type: Web application) in the Google
# Cloud Console and register BOTH redirect URIs below as Authorized redirect
# URIs. The web vs native split exists because the web app and the native app
# hit the backend on different origins.
#GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=your-client-secret
# Callback the browser/PWA flow uses (same origin as the web app).
#   dev:  http://localhost:5173/api/auth/google/callback  (through the Vite proxy)
#   prod: https://spellcontrol.com/api/auth/google/callback
#OAUTH_WEB_REDIRECT_URI=https://spellcontrol.com/api/auth/google/callback
# Callback the Capacitor app's flow uses (the backend's own origin).
#   dev:  http://localhost:3737/api/auth/google/callback
#   prod: https://api.spellcontrol.com/api/auth/google/callback
#OAUTH_NATIVE_REDIRECT_URI=https://api.spellcontrol.com/api/auth/google/callback

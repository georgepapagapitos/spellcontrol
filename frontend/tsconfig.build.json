{
  // Production build typecheck gate (see package.json "build"). Same as
  // tsconfig.json but WITHOUT test files — tests are never shipped, and
  // excluding them keeps the production typecheck focused on shipped code.
  // They are still fully type-checked by the CI "typecheck" script
  // (tsc -b on tsconfig.json).
  "extends": "./tsconfig.json",
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}

<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!--
            Disable Google's Auto Backup / Restore for this app. Auto Backup
            quietly snapshots the WebView's IndexedDB + SharedPreferences to
            the user's Google Drive every 24h and silently restores them on
            reinstall. Because the sync layer's "local cache wins over an
            empty server" invariant treats restored data as the source of
            truth, a reinstall against a different backend (e.g. moving the
            user from a dev environment to production) ends up pushing stale
            binders/decks into the new account. Turning auto-backup off makes
            reinstall behave like a true clean install. If we ever want
            opt-in backup of a small subset (e.g. theme settings only), do
            it via android:dataExtractionRules + a backup_rules.xml allow-list
            and keep WebView storage excluded.
        -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Custom-scheme deep link: `spellcontrol://share/<token>` opens
                straight to the SharedView route. Works without any domain
                verification, so it's safe to ship before the public backend
                URL is decided. HTTPS App Links can be layered on later once
                spellcontrol.app exists and a Digital Asset Links file can
                be hosted at /.well-known/.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="spellcontrol" android:host="share" />
            </intent-filter>

            <!--
                OAuth callback deep link (Android App Link): the backend's
                Google sign-in callback 302s to
                `https://spellcontrol.com/oauth/callback?...` and the OS hands
                the URL straight to this app, bypassing the system browser.
                Requires a matching /.well-known/assetlinks.json on the host
                listing this APK's signing cert fingerprints — Android
                verifies this on install (autoVerify=true). Replaced the
                previous spellcontrol://oauth custom-scheme hop, which
                Firefox / Samsung Internet refused to follow.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="spellcontrol.com"
                    android:pathPrefix="/oauth/callback" />
            </intent-filter>

            <!--
                Legacy custom-scheme fallback: kept for one release cycle so
                any APK out in the wild (or installed before the App Link
                verification lands) still resolves spellcontrol://oauth/...
                URLs locally. The backend no longer emits this scheme; remove
                this filter (and the matching branch in deep-links.ts) in a
                follow-up after the next signed release ships.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="spellcontrol" android:host="oauth" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
</manifest>
